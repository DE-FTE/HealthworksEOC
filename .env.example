# ─── REQUIRED ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

PAGEINDEX_API_KEY=your_pageindex_api_key_here

# ─── PDF STORAGE ──────────────────────────────────────────────────────────────
#
# Option 1 — LOCAL (default, for development)
#   Drop PDF files into the /pdfs folder in the project root.
#
PDF_SOURCE=local
#
# Option 2 — VERCEL BLOB (for production on Vercel)
#   1. Go to Vercel dashboard → Storage → Create Blob store
#   2. Copy the BLOB_READ_WRITE_TOKEN
#   3. Upload PDFs: npx vercel blob put filename.pdf ./path/to/file.pdf
#   4. Set PDF_SOURCE=vercel-blob below
#
# PDF_SOURCE=vercel-blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# ─── VERCEL KV (for production index persistence) ─────────────────────────────
# KV_REST_API_URL=https://your-kv-store.kv.vercel-storage.com
# KV_REST_API_TOKEN=your_kv_token_here

# ─── TUNING ───────────────────────────────────────────────────────────────────
PAGES_PER_NODE=1
MAX_NODES_PER_QUERY=6
SELECTION_MODEL=gpt-4o-mini
ANSWER_MODEL=gpt-4o
